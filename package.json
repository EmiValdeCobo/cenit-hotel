{
  "name": "cenit",
  "version": "1.0.0",
  "description": "Hotel Management System",
  "scripts": {
    "setup": "npm install && npm run install:frontend && npm run install:backend",
    "install:frontend": "cd frontend && npm install",
    "install:backend": "cd backend && python -m venv venv && .\\venv\\Scripts\\pip install -r requirements.txt",
    "dev": "concurrently -k -n \"BACKEND,FRONTEND\" -c \"blue,magenta\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && docker-compose up --build",
    "dev:frontend": "cd frontend && npm run dev",
    "docker:down": "cd backend && docker-compose down"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
